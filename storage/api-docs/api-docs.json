        "/api/v1/mahasiswa/{id}": {
            "get": {
                "tags": [
                    "Mahasiswa"
                ],
                "summary": "Lihat detail mahasiswa berdasarkan ID or NIM",
                "operationId": "a234c3ccf3047ab381190dd162db20c0",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Data mahasiswa ditemukan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Data retrieved successfully"
                                        },
                                        "data": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "nim": {
                                                    "type": "string",
                                                    "example": "1301210001"
                                                },
                                                "nama": {
                                                    "type": "string",
                                                    "example": "Budi Santoso"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "example": "budi@student.tel.ac.id"
                                                },
                                                "prodi": {
                                                    "type": "string",
                                                    "example": "S1 Sistem Informasi"
                                                },
                                                "angkatan": {
                                                    "type": "integer",
